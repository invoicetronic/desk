@page
@model Desk.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = L["Auth_Register"].Value;
    Layout = null;
}

<!DOCTYPE html>
<html lang="@(((DeskConfig)ViewContext.HttpContext.RequestServices.GetService(typeof(DeskConfig))!).Locale)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Zain:wght@700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme-default.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/custom/theme.css" onerror="this.remove()" />
</head>
<body>
    <div class="desk-auth-layout">
        <div class="desk-card desk-auth-card">
            <div class="desk-auth-logo">
                <img src="~/images/logo-green.svg" alt="Logo" />
            </div>
            <h1 class="desk-auth-title" style="font-size: var(--text-xl);">@L["Auth_RegisterTitle"]</h1>

            <div asp-validation-summary="ModelOnly" class="desk-alert desk-alert-danger" style="margin-bottom: var(--space-5);"></div>

            <form method="post" novalidate>
                <div class="desk-form-group">
                    <label class="desk-label" asp-for="Input.DisplayName">@L["Auth_DisplayName"]</label>
                    <input asp-for="Input.DisplayName" class="desk-input" autocomplete="name" autofocus />
                    <span asp-validation-for="Input.DisplayName" class="text-danger text-xs"></span>
                </div>
                <div class="desk-form-group">
                    <label class="desk-label" asp-for="Input.Email">@L["Auth_Email"]</label>
                    <input asp-for="Input.Email" class="desk-input" type="email" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="text-danger text-xs"></span>
                </div>
                <div class="desk-form-group">
                    <label class="desk-label" asp-for="Input.Password">@L["Auth_Password"]</label>
                    <input asp-for="Input.Password" class="desk-input" type="password" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger text-xs"></span>
                </div>
                <div class="desk-form-group">
                    <label class="desk-label" asp-for="Input.ConfirmPassword">@L["Auth_ConfirmPassword"]</label>
                    <input asp-for="Input.ConfirmPassword" class="desk-input" type="password" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger text-xs"></span>
                </div>

                @if (Model.IsBillingEnabled)
                {
                    <hr style="margin: var(--space-5) 0; border-color: var(--color-border);" />
                    <h2 style="font-size: var(--text-base); margin-bottom: var(--space-2);">@L["Profile_BillingInfo"]</h2>
                    <p class="text-xs text-muted" style="margin-bottom: var(--space-4);">@L["Profile_BillingInfoNotUsedDuringTrial"]</p>

                    <div class="desk-form-group">
                        <label class="desk-label" asp-for="BillingProfile!.CompanyName">@L["Profile_CompanyName"]</label>
                        <input asp-for="BillingProfile!.CompanyName" class="desk-input" />
                        <span asp-validation-for="BillingProfile!.CompanyName" class="text-danger text-xs"></span>
                    </div>
                    <div class="desk-form-group">
                        <label class="desk-label" asp-for="BillingProfile!.Address">@L["Profile_Address"]</label>
                        <input asp-for="BillingProfile!.Address" class="desk-input" />
                        <span asp-validation-for="BillingProfile!.Address" class="text-danger text-xs"></span>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);">
                        <div class="desk-form-group">
                            <label class="desk-label" asp-for="BillingProfile!.City">@L["Profile_City"]</label>
                            <input asp-for="BillingProfile!.City" class="desk-input" />
                            <span asp-validation-for="BillingProfile!.City" class="text-danger text-xs"></span>
                        </div>
                        <div class="desk-form-group">
                            <label class="desk-label" asp-for="BillingProfile!.ZipCode">@L["Profile_ZipCode"]</label>
                            <input asp-for="BillingProfile!.ZipCode" class="desk-input" />
                            <span asp-validation-for="BillingProfile!.ZipCode" class="text-danger text-xs"></span>
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);">
                        <div class="desk-form-group">
                            <label class="desk-label" asp-for="BillingProfile!.State">@L["Profile_State"]</label>
                            <input asp-for="BillingProfile!.State" class="desk-input" />
                            <span asp-validation-for="BillingProfile!.State" class="text-danger text-xs"></span>
                        </div>
                        <div class="desk-form-group">
                            <label class="desk-label" asp-for="BillingProfile!.Country">@L["Profile_Country"]</label>
                            <select asp-for="BillingProfile!.Country" asp-items="Desk.Countries.GetList()" class="desk-input"></select>
                            <span asp-validation-for="BillingProfile!.Country" class="text-danger text-xs"></span>
                        </div>
                    </div>
                    <div class="desk-form-group">
                        <label class="desk-label" asp-for="BillingProfile!.PhoneNumber">@L["Profile_PhoneNumber"]</label>
                        <input asp-for="BillingProfile!.PhoneNumber" class="desk-input" type="tel" />
                        <span asp-validation-for="BillingProfile!.PhoneNumber" class="text-danger text-xs"></span>
                    </div>
                    <div class="desk-form-group">
                        <label class="desk-label" asp-for="BillingProfile!.TaxId">@L["Profile_TaxId"]</label>
                        <input asp-for="BillingProfile!.TaxId" class="desk-input" />
                        <span asp-validation-for="BillingProfile!.TaxId" class="text-danger text-xs"></span>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);">
                        <div class="desk-form-group">
                            <label class="desk-label" asp-for="BillingProfile!.CodiceDestinatario">@L["Profile_CodiceDestinatario"]</label>
                            <input asp-for="BillingProfile!.CodiceDestinatario" class="desk-input" />
                            <span asp-validation-for="BillingProfile!.CodiceDestinatario" class="text-danger text-xs"></span>
                        </div>
                        <div class="desk-form-group">
                            <label class="desk-label" asp-for="BillingProfile!.PecMail">@L["Profile_Pec"]</label>
                            <input asp-for="BillingProfile!.PecMail" class="desk-input" type="email" />
                            <span asp-validation-for="BillingProfile!.PecMail" class="text-danger text-xs"></span>
                        </div>
                    </div>
                    <p class="text-xs text-muted" style="margin-bottom: var(--space-4);">@L["Profile_ItalianFieldsNote"]</p>
                }

                <button type="submit" class="btn-brand btn-brand-primary" style="width: 100%; justify-content: center;">
                    @L["Auth_Register"]
                </button>
            </form>

            <p class="text-sm text-muted" style="text-align: center; margin-top: var(--space-6);">
                @L["Auth_HaveAccount"] <a href="/Identity/Account/Login">@L["Auth_Login"]</a>
            </p>
        </div>
    </div>
</body>
</html>
