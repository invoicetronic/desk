@inject DeskConfig Config
@inject Microsoft.AspNetCore.Identity.UserManager<Desk.Data.DeskUser> UserManager
<!DOCTYPE html>
<html lang="@(Config.Locale ?? System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Config.Branding.AppName</title>
    <link rel="icon" type="image/png" href="@(Config.Branding.FaviconUrl ?? Url.Content("~/images/favicon.png"))" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Zain:wght@700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme-default.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ag-grid-overrides.css" asp-append-version="true" />
    @if (Config.Branding.PrimaryColor is not null || Config.Branding.AccentColor is not null)
    {
        <style>
            :root {
                @if (Config.Branding.PrimaryColor is not null) { @: --brand-primary: @Config.Branding.PrimaryColor;
                }
                @if (Config.Branding.AccentColor is not null) { @: --brand-accent: @Config.Branding.AccentColor;
                }
            }
        </style>
    }
    <link rel="stylesheet" href="~/custom/theme.css" onerror="this.remove()" />
</head>
<body>
    <div class="desk-app">
        <partial name="_Navbar" />
        <partial name="_SubNav" />

        @if (Config.IsBillingEnabled && User.Identity?.IsAuthenticated == true)
        {
            var deskUser = await UserManager.GetUserAsync(User);
            if (deskUser is not null && deskUser.SubscriptionStatus is not ("active" or "trialing"))
            {
                var daysLeft = Desk.Pages.AppPageModel.PreviewDays - (int)(DateTime.UtcNow - deskUser.CreatedAt).TotalDays;
                if (daysLeft > 0)
                {
                    <div style="background: #f59e0b; color: #1a1a1a; text-align: center; padding: var(--space-2) var(--space-4); font-size: var(--text-sm); font-weight: 500;">
                        @L["Billing_PreviewBanner", daysLeft]
                        <a href="/Billing/Subscribe" style="color: #1a1a1a; font-weight: 700; text-decoration: underline; margin-left: var(--space-2);">@L["Billing_SubscribeNow"]</a>
                    </div>
                }
            }
        }

        <main class="desk-content">
            @RenderBody()
        </main>

        <partial name="_Footer" />
    </div>

    <script src="~/js/company-selector.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@35.1.0/dist/ag-grid-community.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
