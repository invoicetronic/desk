@inject DeskConfig Config
<!DOCTYPE html>
<html lang="@(Config.Locale ?? System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Config.Branding.AppName</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Zain:wght@700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme-default.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ag-grid-overrides.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/custom/theme.css" onerror="this.remove()" />
</head>
<body>
    <div class="desk-app">
        <partial name="_Navbar" />
        <partial name="_SubNav" />

        <main class="desk-content">
            @RenderBody()
        </main>

        <partial name="_Footer" />
    </div>

    <script src="~/js/company-selector.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@35.1.0/dist/ag-grid-community.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
