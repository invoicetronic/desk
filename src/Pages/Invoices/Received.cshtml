@page
@model Desk.Pages.Invoices.ReceivedModel
@{
    ViewData["Title"] = L["Invoices_ReceivedTitle"].Value;
    ViewData["ActiveNav"] = "Received";
}

<div class="desk-page-header">
    <h1 class="desk-page-title">@L["Invoices_ReceivedTitle"]</h1>
</div>

<div class="desk-grid-wrapper">
    <div class="desk-grid-toolbar">
        <div class="desk-grid-filters">
            <input type="search" id="filterSearch" class="desk-input" style="width:260px"
                   placeholder="@L["Invoices_SearchPlaceholder"].Value" />
            <label class="desk-filter-check">
                <input type="checkbox" id="filterUnread" onchange="applyFilters()" />
                <span>@L["Invoices_UnreadOnly"]</span>
            </label>
            <button class="btn-brand btn-brand-primary btn-brand-sm" onclick="applyFilters()">
                @L["Common_Search"]
            </button>
        </div>
    </div>
    <div id="receivedGrid" style="width: 100%;"></div>
</div>

@section Scripts {
    <script src="~/js/ag-grid-init.js" asp-append-version="true"></script>
    <script>
        const listUrl = '/Invoices/Received?handler=List';
        const unreadLabel = '@L["Invoices_Unread"].Value';
        const readLabel = '@L["Invoices_Read"].Value';
        const detailLabel = '@L["Invoices_DetailTitle"].Value';
        const downloadLabel = '@L["Invoices_DownloadXml"].Value';
        let gridApi = null;

        function getFilterParams() {
            const params = {};
            const q = document.getElementById('filterSearch').value.trim();
            const unread = document.getElementById('filterUnread').checked;
            if (q) params.q = q;
            if (unread) params.unreadOnly = 'true';
            return params;
        }

        function applyFilters() {
            gridApi.setGridOption('datasource', createDatasource(listUrl, getFilterParams));
        }

        async function downloadInvoice(id) {
            const url = '/Invoices/Detail?handler=Download&type=receive&id=' + id;
            try {
                const resp = await fetch(url, { credentials: 'same-origin' });
                if (!resp.ok) return;

                const blob = await resp.blob();
                const cd = resp.headers.get('content-disposition') || '';
                const m = cd.match(/filename\*?=(?:UTF-8''|")?([^";]+)"?/i);
                const fileName = m ? decodeURIComponent(m[1]) : 'invoice.xml';

                const a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                setTimeout(() => URL.revokeObjectURL(a.href), 60000);

                // Mark row as read in grid
                gridApi.forEachNode(node => {
                    if (node.data && node.data.id === id) {
                        node.data.isRead = true;
                        gridApi.refreshCells({ rowNodes: [node], columns: ['isRead'], force: true });
                    }
                });
            } catch (e) {
                console.error('Download failed:', e);
            }
        }

        function formatDate(val) {
            if (!val) return '';
            return new Date(val).toLocaleDateString();
        }

        function formatDocuments(data) {
            if (!data || !data.documents || data.documents.length === 0) return '';
            var doc = data.documents[0];
            return doc.number || '';
        }

        function formatDocDate(data) {
            if (!data || !data.documents || data.documents.length === 0) return '';
            var doc = data.documents[0];
            return doc.date ? new Date(doc.date).toLocaleDateString() : '';
        }

        document.addEventListener('DOMContentLoaded', function () {
            gridApi = initGrid('receivedGrid', {
                columnDefs: [
                    {
                        field: 'isRead',
                        headerName: '@L["Invoices_IsRead"].Value',
                        width: 50,
                        sortable: false,
                        cellRenderer: function(p) {
                            if (!p.data) return '';
                            return p.data.isRead
                                ? '<span title="' + readLabel + '" style="opacity:0.3">●</span>'
                                : '<span title="' + unreadLabel + '" style="color:var(--brand-accent);font-weight:bold">●</span>';
                        }
                    },
                    {
                        field: 'identifier',
                        headerName: '@L["Invoices_Identifier"].Value',
                        flex: 1.2,
                        cellRenderer: function(p) {
                            if (!p.data) return '';
                            return '<a href="/Invoices/Detail?type=receive&id=' + p.data.id + '" style="color:var(--brand-accent);font-weight:500">' +
                                   (p.data.identifier || '—') + '</a>';
                        }
                    },
                    { field: 'prestatore', headerName: '@L["Invoices_Prestatore"].Value', flex: 1.5 },
                    {
                        headerName: '@L["Invoices_DocumentNumber"].Value',
                        flex: 0.8,
                        sortable: false,
                        valueGetter: function(p) { return p.data ? formatDocuments(p.data) : ''; }
                    },
                    {
                        headerName: '@L["Invoices_DocumentDate"].Value',
                        flex: 0.9,
                        sortable: false,
                        valueGetter: function(p) { return p.data ? formatDocDate(p.data) : ''; }
                    },
                    {
                        headerName: '',
                        sortable: false,
                        resizable: false,
                        width: 90,
                        cellRenderer: function(p) {
                            if (!p.data) return '';
                            return '<a class="btn-icon" href="/Invoices/Detail?type=receive&id=' + p.data.id + '" title="' + detailLabel + '"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></a>' +
                                   '<a class="btn-icon" href="javascript:void(0)" onclick="downloadInvoice(' + p.data.id + ')" title="' + downloadLabel + '"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></a>';
                        }
                    }
                ],
                datasource: createDatasource(listUrl, getFilterParams),
                cacheBlockSize: 20,
                paginationPageSize: 20,
                onRowDoubleClicked: function(e) {
                    if (e.data) window.location.href = '/Invoices/Detail?type=receive&id=' + e.data.id;
                },
            });

            const searchField = document.getElementById('filterSearch');
            searchField.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') applyFilters();
            });
            searchField.addEventListener('search', applyFilters);
        });
    </script>
    <style>
        .desk-filter-check {
            display: inline-flex;
            align-items: center;
            gap: var(--space-2);
            font-size: var(--text-sm);
            color: var(--color-text);
            cursor: pointer;
            white-space: nowrap;
        }
        .desk-filter-check input[type="checkbox"] {
            accent-color: var(--brand-accent);
            width: 16px;
            height: 16px;
        }
    </style>
}
