# desk.yml - Invoicetronic Desk configuration

desk:
  # Invoicetronic API
  api_url: https://api.invoicetronic.com/v1

  # API key (optional) — if set, Desk runs WITHOUT registration/login.
  # All API calls use this key. No Identity, no local DB.
  # Useful for ISVs self-hosting on a trusted internal network.
  # If omitted, Desk requires registration and each user enters their own key.
  # api_key: itk_live_xxxxxxxxxx
  # Tip: to avoid storing the key in a file, use the env var Desk__api_key

  # Database (ignored when api_key is set — no local DB needed)
  database:
    provider: sqlite           # sqlite | pgsql
    # sqlite: default path data/desk.db
    # pgsql: connection_string via env var Desk__database__connection_string

  # Branding
  branding:
    app_name: Invoicetronic Desk
    footer_text: 'Powered by <a href="https://invoicetronic.com">Invoicetronic</a>'
    # logo_url: https://example.com/logo-light.svg       # navbar (dark background)
    # logo_dark_url: https://example.com/logo-dark.svg    # auth pages (light background)
    # favicon_url: https://example.com/favicon.png
    # primary_color: "#1A237E"
    # accent_color: "#E91E63"

  # SMTP (optional) — required for password reset in multi-user mode.
  # If not configured, the "Forgot password?" link is not shown on the login page.
  # smtp:
  #   host: smtp.example.com
  #   port: 587                  # 587 (StartTLS) | 465 (SSL)
  #   username: user@example.com
  #   password: secret
  #   sender_email: noreply@example.com
  #   sender_name: Invoicetronic Desk

  # Localization
  locale: it                   # it | en
