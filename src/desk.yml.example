# desk.yml - Configurazione Invoicetronic Desk

desk:
  # API Invoicetronic
  api_url: https://api.invoicetronic.com/v1

  # API key (opzionale) — se presente, Desk gira SENZA registrazione/login
  # Tutte le chiamate API usano questa key. Niente Identity, niente DB locale.
  # Utile per ISV che self-hostano in rete interna sicura.
  # Se assente, Desk richiede registrazione e ogni utente inserisce la propria key.
  # api_key: itk_live_xxxxxxxxxx
  # Consiglio: per non salvare la key su file, usare la env var Desk__api_key

  # Database (ignorato se api_key è presente — non serve DB locale)
  database:
    provider: sqlite           # sqlite | pgsql
    # sqlite: path default desk.db (nella directory dell'app)
    # pgsql: connection string da env var Desk__Database__ConnectionString

  # Branding
  branding:
    app_name: Invoicetronic Desk
    footer_text: 'Powered by <a href="https://invoicetronic.com">Invoicetronic</a>'
    # logo_url: https://example.com/logo-light.svg       # navbar (sfondo scuro)
    # logo_dark_url: https://example.com/logo-dark.svg    # pagine auth (sfondo chiaro)
    # favicon_url: https://example.com/favicon.png
    # primary_color: "#1A237E"
    # accent_color: "#E91E63"

  # Localizzazione
  locale: it                   # it | en
